{{- if eq .machine "personal" }}
tap "kamillobinski/thock"
tap "laishulu/homebrew"
tap "supabase/tap"
{{- end }}

# === Core (both machines) ===
brew "age"
brew "chezmoi"
brew "bitwarden-cli"

# === Shell / Prompt (both) ===
brew "starship"
brew "tmux"
brew "zoxide"
brew "zsh-autosuggestions"
brew "zsh-completions"
brew "zsh-syntax-highlighting"

# === CLI utilities (both) ===
brew "bat"
brew "cloudflared"
brew "direnv"
brew "eza"
brew "fd"
brew "fzf"
brew "gh"
brew "git-lfs"
brew "jq"
brew "lazygit"
brew "ripgrep"
brew "wget"

# === Runtime / Version managers (both) ===
brew "mise"
brew "pyenv"

# === Security / Auth (both) ===
brew "gnupg"
brew "pinentry-mac"

# === Casks (both) ===
cask "1password-cli"
cask "font-rounded-mplus"
cask "ghostty"

{{- if eq .machine "work" }}

# === Work-only: Cloud / Infra ===
brew "tfenv"
brew "kubernetes-cli"
brew "clamav"
cask "aws-vault-binary"
cask "font-monaspice-nerd-font"
{{- end }}

