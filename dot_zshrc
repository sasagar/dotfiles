export PATH="$HOME/.local/bin:$PATH"

# --- zsh 補完システム初期化 ---
autoload -Uz compinit && compinit
# --- Python ---
export PATH="$(brew --prefix python)/libexec/bin:$PATH"

export EDITOR=vi

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# --- eza (lsの置き換え: アイコン表示を有効化) ---
alias ls='eza --icons --git'
alias l='eza -lh --icons --git'
alias la='eza -a --icons --git'
alias ll='eza -lh --icons --git'

# --- fzf 連携設定 ---
# fdをデフォルトの検索コマンドに（隠しファイルを検索対象にしつつ.gitなどは除外）
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# batをfzfのプレビューとして使用（Nerd Fonts環境なら非常に見栄えが良い）
export FZF_DEFAULT_OPTS="--preview 'bat --color=always --style=header,grid --line-range :500 {}'"

# fzf追加設定
alias cf='cd $(ghq list --full-path | fzf)'

# --- starship (プロンプトの初期化) ---
export STARSHIP_CONFIG="$HOME/.config/starship.toml"
eval "$(starship init zsh)"
eval "$(mise activate zsh)"

# --- AWSume ---
alias awsume="source $(pyenv which awsume)"

# Auto-Complete function for AWSume (zsh)
_awsume() {
    local -a opts
    opts=(${(f)"$(awsume-autocomplete)"})
    _describe 'awsume' opts
}
compdef _awsume awsume

# --- direnv ---
eval "$(direnv hook zsh)"

# --- 1Password ---
## 2FAのOne-Time Passwordについて取得する関数
function 2fa() {
  local code=$(op item get "$1" --otp)
  echo -n "$code" | pbcopy  # macOSの場合
  echo "OTP for $1 copied to clipboard: $code"
}

# --- Bitwarden / VaultWarden ---
## bw unlock を実行してセッションキーを環境変数にセットする
bwu() {
  export BW_SESSION=$(bw unlock --raw)
}

# --- Work-specific settings (encrypted, chezmoi-managed) ---
[ -f ~/.zshrc.work ] && source ~/.zshrc.work

# --- zoxide (cdの置き換え) ※シェル設定ファイルの末尾で初期化すること ---
eval "$(zoxide init zsh)"
alias cd='z'
alias zi='z -i' # fzfを使ったインタラクティブ移動
