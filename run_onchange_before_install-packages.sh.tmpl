#!/bin/bash
# Brewfile hash: {{ include "Brewfile.tmpl" | sha256sum }}
set -euo pipefail

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is not installed. Install it first: https://brew.sh"
  exit 1
fi

# run_onchange_before_* は ~/Brewfile が配置される前に実行されるため、
# テンプレートを一時ファイルに render してから brew bundle に渡す。
TEMP_BREWFILE=$(mktemp -t chezmoi-Brewfile.XXXXXX)
trap 'rm -f "$TEMP_BREWFILE"' EXIT

cat > "$TEMP_BREWFILE" <<'CHEZMOI_BREWFILE_EOF'
{{ includeTemplate "Brewfile.tmpl" . -}}
CHEZMOI_BREWFILE_EOF

brew bundle --file="$TEMP_BREWFILE"
